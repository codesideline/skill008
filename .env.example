# Copy to .env.local for local dev, and set these in Vercel for production.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (the skill generator runs on Claude) ---
# Without this key, skill generation returns a 500. The rest of the site works.
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-sonnet-4-6 in src/lib/generate.ts
ANTHROPIC_MODEL=

# --- Site ---
# Set to your production URL in Vercel, e.g. https://skill008.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=hello@skill008.app
